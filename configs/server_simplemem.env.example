# Copy this to .env at the repository root, or export the variables in your shell.
# The CLI loads repository-root .env automatically.
# Values mirror the server SimpleMem setup, but API keys remain local secrets.

HF_HOME=.cache/huggingface
TRANSFORMERS_CACHE=.cache/huggingface

EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_BACKEND=hf

ANSWERER_BASE_URL=https://llmapi.paratera.com/v1/
ANSWERER_MODEL=Qwen3-30B-A3B-Instruct-2507
ANSWERER_API_KEY=replace_with_your_key

JUDGE_BASE_URL=https://llmapi.paratera.com/v1/
JUDGE_MODEL=DeepSeek-V4-Flash
JUDGE_API_KEY=replace_with_your_key
