# Copy to .env. The CLI loads .env automatically.
# Keep real API keys only in .env; .env is git-ignored.

# Shared OpenAI-compatible API
OPENAI_BASE_URL=https://llmapi.paratera.com/v1/
OPENAI_API_KEY=replace_with_your_key
LLM_MODEL=Qwen3-30B-A3B-Instruct-2507

# Answerer API
ANSWERER_BASE_URL=https://llmapi.paratera.com/v1/
ANSWERER_API_KEY=replace_with_your_key
ANSWERER_MODEL=Qwen3-30B-A3B-Instruct-2507
ANSWER_BASE_URL=https://llmapi.paratera.com/v1/
ANSWER_API_KEY=replace_with_your_key
ANSWER_MODEL=Qwen3-30B-A3B-Instruct-2507

# Judge API
JUDGE_BASE_URL=https://llmapi.paratera.com/v1/
JUDGE_API_KEY=replace_with_your_key
JUDGE_MODEL=DeepSeek-V4-Flash

# HuggingFace local embedding cache
HF_HOME=.cache/huggingface
TRANSFORMERS_CACHE=.cache/huggingface

# Embedding models. Default stays on cached 0.6B; 4B is downloaded for later switch.
EMBEDDING_BACKEND=hf
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDER_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIMENSION=1024
EMBEDDING_MODEL_0_6B=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_MODEL_4B=Qwen/Qwen3-Embedding-4B
EMBEDDING_MODEL_4B_DIMENSION=2560
EMBEDDING_BATCH_SIZE=16
